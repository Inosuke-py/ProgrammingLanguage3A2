# ─── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV: standard postgres
# DATABASE_URL=postgresql://postgres:law@localhost:5432/kino
#
# PRODUCTION (Supabase pooled, IPv4-friendly):
#   1. Go to your Supabase dashboard → click "Connect" (top-right of project)
#   2. Pick the "Direct" tab if your VPS supports IPv6, or use the Transaction
#      pooler URI (port 6543) for the broadest compatibility
#   3. Replace [YOUR-PASSWORD] with your DB password
#
# Format:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.volxaiafoennnwxpvmsx:YOUR-DB-PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this
# Local dev:
# FRONTEND_URL=http://localhost:5173
# Production:
FRONTEND_URL=https://mykino.fun

# ─── AI - Mistral API (primary, much faster) ─────────────────────────────────
AI_BACKEND=mistral
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-small-latest

# ─── AI - Ollama (fallback, local) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ─── File storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
